{
  "name": "add-git-repos",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [
    "onCommand:extension.addReposFromFolder"
  ],
  "contributes": {
    "commands": [
      {
        "command": "extension.addReposFromFolder",
        "title": "Add Git Repos from Selection"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.addReposFromFolder",
          "group": "2_workspace",
          "when": "explorerResourceIsFolder"
        }
      ]
    }
  },
  "main": "./extension.js",
  "devDependencies": {
    "@types/vscode": "^1.115.0"
  }
}
